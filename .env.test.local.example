# ── Live E2E Test Credentials ────────────────────────────────────────────────
# Copy this file to .env.test.local and fill in the values.
# NEVER commit .env.test.local — it is gitignored.
# NEVER use production wallet keys or admin passwords here.

# A dedicated test wallet private key.
# Generate one: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# Fund it with a tiny amount of testnet ETH if needed (live tests on mainnet should be read-only).
E2E_WALLET_PRIVATE_KEY=0x_YOUR_TEST_PRIVATE_KEY_HERE

# An email that is listed in your ADMIN_EMAILS server env var.
E2E_ADMIN_EMAIL=admin@p402.io

# The password for that admin account.
# Set it first with: npx tsx scripts/set-admin-password.ts
E2E_ADMIN_PASSWORD=your_admin_password_here
