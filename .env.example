# ============================================
# P402 Router — Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# ── Google OAuth (NextAuth provider) ─────────────────────────────────────────
# https://console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash recommended for Vercel: rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe Dashboard → Webhooks → signing secret (set after registering endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Products → price IDs
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ── AI Providers ──────────────────────────────────────────────────────────────
# OpenRouter covers 300+ models with one key (recommended as primary)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Required for Gemini intelligence layer + text-embedding-004 (semantic cache)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional — OpenRouter covers these providers too
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Base Network ──────────────────────────────────────────────────────────────
# RPC endpoint for on-chain reads/writes (subscription billing, x402 settlement)
# Defaults to public https://mainnet.base.org if not set (rate-limited)
# Recommended: Alchemy/QuickNode Base endpoint for production
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
# Treasury address — must match the address set in deployed contracts
P402_TREASURY_ADDRESS=0xFa772434DCe6ED78831EbC9eeAcbDF42E2A031a6

# ── Coinbase Developer Platform (CDP) ────────────────────────────────────────
# https://portal.cdp.coinbase.com → API Keys
# Required for: CDP Embedded Wallet (email OTP auth) + CDP Server Wallet (TEE key storage)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# CDP project ID for embedded wallet (frontend)
NEXT_PUBLIC_CDP_PROJECT_ID=81080910-ed18-480f-8633-70289ef0baac
# Optional: custom name for the facilitator server wallet (default: p402-facilitator)
CDP_FACILITATOR_WALLET_NAME=p402-facilitator
# Set to true to use CDP Server Wallet instead of raw private key for settlement
CDP_SERVER_WALLET_ENABLED=false

# ── x402 Facilitator ──────────────────────────────────────────────────────────
# Legacy raw private key — only required when CDP_SERVER_WALLET_ENABLED=false
# When CDP_SERVER_WALLET_ENABLED=true, keys live in CDP TEE (AWS Nitro Enclave)
P402_SIGNER_ADDRESS=0x...
P402_FACILITATOR_PRIVATE_KEY=0x...
# Receipt HMAC signing key — required. Generate: openssl rand -hex 32
P402_RECEIPT_SECRET=

# ── Deployed Contracts (Base Mainnet) ─────────────────────────────────────────
# Fee-collecting marketplace settlement contract (1% fee → treasury)
P402_SETTLEMENT_ADDRESS=0xd03c7ab9a84d86dbc171367168317d6ebe408601
# EIP-2612 permit-based subscription billing ($499/mo USDC → treasury)
SUBSCRIPTION_FACILITATOR_ADDRESS=0xc64747651e977464af5bce98895ca6018a3e26d7
# Conditional USDC escrow (Phase 3 — deployed 2026-03-22)
P402_ESCROW_ADDRESS=0x4596c0e69d08e4ca6f02c7a129fc2bff8a6905ac

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://p402.io,https://www.p402.io,https://mini.p402.io

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=
# Auth token for Vercel cron jobs
CRON_SECRET=
# Auth token for internal poll endpoints
POLL_SECRET=

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_SEMANTIC_CACHE=true
ENABLE_COST_INTELLIGENCE=true

# ── Notifications (optional) ──────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin role on first login
ADMIN_EMAILS=

# ── Tempo Mainnet Direct facilitator (all optional; only required when Tempo adapter is enabled) ──
# Treasury address that receives settled TIP-20 stablecoins on Tempo mainnet (chain ID 4217).
# Must be stored in EIP-55 checksummed form (preserve the exact case).
TEMPO_TREASURY_ADDRESS=
# Private key for the Tempo treasury wallet.
# SENSITIVE — load from secrets manager in production; never commit this value.
TEMPO_TREASURY_PRIVATE_KEY=
# Tempo mainnet JSON-RPC endpoint. Default public endpoint: https://rpc.tempo.xyz
# (WSS: wss://rpc.tempo.xyz). Use a private node for production throughput.
# ⚠ viem 2.46.3 ships `tempo` chain with a stale URL (rpc.presto.tempo.xyz — pre-mainnet
#   codename). This env var overrides it. If unset, lib/constants/tempo.ts falls back to
#   https://rpc.tempo.xyz directly.
TEMPO_RPC_URL=https://rpc.tempo.xyz
# Supported TIP-20 stablecoin contracts are defined in lib/constants/tempo.ts
# (TEMPO_SUPPORTED_CURRENCIES) and synced to the DB via migration v2_038.
# No per-currency env vars needed — add new tokens to the constants file instead.

# ── mppx Dual-Protocol Payment Gate (Phase 2.1) ─────────────────────────────
# Enable the mppx/tempo payment path on /api/v2/chat/completions.
# When true: clients with "Authorization: Payment <...>" header pay per-request.
# Clients without payment credentials that also lack an API key receive a dual
# 402 response with both WWW-Authenticate (mppx) and X-PAYMENT-REQUIRED (x402).
# x402 X-PAYMENT backwards-compat guaranteed through May 2027.
USE_MPP_METHOD=false
# HMAC secret for mppx challenge signing. Generate: openssl rand -hex 32
# Required when USE_MPP_METHOD=true. Min 32 chars.
MPP_SECRET_KEY=
# Per-request charge amount in human-readable USDC decimal (mppx format).
# Default: 0.001 = $0.001 = 1000 raw USDC.e units. Dynamic per-token pricing: Phase 3.3.
MPP_CHARGE_AMOUNT_USD=0.001
# Switch to the @p402/mpp-method p402Charge method instead of native tempo().
# When true: uses P402's own credential format (sessionToken + ECDSA signature).
# P402_FACILITATOR_PRIVATE_KEY is NOT required in this mode.
# verifyP402Charge() stub returns success; real settlement wired in Phase 3.
USE_P402_MPP_METHOD=false

# ── Phase 1 Tempo Settlement Test (local dev only — NEVER add to Vercel) ─────
# These variables are used ONLY by scripts/test-tempo-settlement.ts.
# CRITICAL: TEST_SENDER_PRIVATE_KEY is sensitive material.
#   - NEVER add it to Vercel env vars.
#   - NEVER commit it (it must stay in .env.local only).
#   - Use it only on your developer laptop for end-to-end settlement testing.
#   - The test sender wallet exists for Phase 1 E2E testing only.
#     It is NOT a treasury and should hold only small balances (~$5 USDC.e).
#   - Derives to address 0x66BFD98Eddb19EdD8b357ccd67fBDdA41ddB3A2b on Tempo mainnet.
#     The script validates this derivation at startup and refuses to proceed if it mismatches.
TEST_SENDER_ADDRESS=0x66BFD98Eddb19EdD8b357ccd67fBDdA41ddB3A2b
TEST_SENDER_PRIVATE_KEY=

# Set to 'true' to actually submit a transaction in scripts/test-tempo-settlement.ts.
# Default (unset or any other value) runs the script in dry-run mode with no spending.
# After a successful live run, .tempo-settle-result.json is written to the repo root as
# an idempotency marker; delete it before running live again (prevents double-spending).
TEMPO_LIVE_SETTLE=

# ── ERC-8004 Trustless Agents (all optional, default disabled) ────────────────
ERC8004_AGENT_ID=
ERC8004_AGENT_URI=https://p402.io/.well-known/erc8004.json
ERC8004_TESTNET=false
ERC8004_ENABLE_REPUTATION=false
ERC8004_ENABLE_VALIDATION=false

# ── World Mini App ────────────────────────────────────────────────────────────
# App ID from developer.worldcoin.org (also set as NEXT_PUBLIC_APP_ID in p402_world Vercel project)
NEXT_PUBLIC_APP_ID=app_...
# Action ID registered in Developer Portal → Actions (used for World ID proof verification)
WORLD_ACTION_ID=p402-free-credits
# Action ID used client-side in the mini app (must match WORLD_ACTION_ID)
NEXT_PUBLIC_WORLD_ACTION_ID=p402-free-credits

# ── Dune Analytics (optional, for dune-sync.ts) ──────────────────────────────
# https://dune.com/settings/api
DUNE_API_KEY=
DUNE_NAMESPACE=p402   # your Dune username / namespace
