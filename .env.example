# ============================================
# P402 Router V2 Environment Variables
# ============================================

# Database Connecton (Neon)
DATABASE_URL=postgresql://user:pass@host.neon.tech/p402?sslmode=require

# CORS Configuration
CORS_ORIGINS=https://mini.p402.io,https://p402.io,https://www.p402.io,http://localhost:3000,http://localhost:3001

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# Security
JWT_SECRET=development_secret_do_not_use_in_production

# x402 Facilitator
P402_SIGNER_ADDRESS=0xYOUR_SIGNER_ADDRESS
P402_FACILITATOR_PRIVATE_KEY=0xYOUR_FACILITATOR_PRIVATE_KEY

# Features
ENABLE_SEMANTIC_CACHE=true
ENABLE_COST_INTELLIGENCE=true

# ERC-8004 Trustless Agents
ERC8004_AGENT_ID=                        # P402's on-chain agent token ID (set after registration)
ERC8004_AGENT_URI=https://p402.io/.well-known/erc8004.json
ERC8004_TESTNET=false                    # Use Base Sepolia registries
ERC8004_ENABLE_REPUTATION=false          # Enable reputation-aware routing & feedback
ERC8004_ENABLE_VALIDATION=false          # Enable validation registry for high-value txs
