# ============================================
# P402 Router — Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================
#
# CLIENT-VS-SERVER VISIBILITY:
#   Only variables prefixed NEXT_PUBLIC_ are exposed to the browser. Every other
#   variable below is server-only. Never prefix secrets, private keys, API keys,
#   HMAC secrets, encryption keys, or internal secrets with NEXT_PUBLIC_.
#
# MINIMUM CONTROLLED BETA CHECKLIST (set in Vercel before any beta traffic):
#   - DATABASE_URL
#   - NEXTAUTH_SECRET
#   - NEXTAUTH_URL
#   - GOOGLE_CLIENT_ID
#   - GOOGLE_CLIENT_SECRET
#   - ADMIN_EMAILS
#   - STRIPE_SECRET_KEY        (if billing is enabled)
#   - BASE_RPC_URL
#   - OPENROUTER_API_KEY       (primary production LLM provider — required)
#   - OPENROUTER_REFERER       (required for OpenRouter app attribution)
#   - INTERNAL_API_SECRET
#   - NEXT_PUBLIC_APP_URL
#   - BUDGET_GUARD_SPEND_SOURCE
#   - P402_RECEIPT_SECRET
#
# If Cloudflare credits will be used during beta, also set:
#   - CLOUDFLARE_ACCOUNT_ID            (if Cloudflare testing is enabled)
#   - CLOUDFLARE_API_TOKEN             (if Cloudflare testing is enabled)
#   - CLOUDFLARE_AI_GATEWAY_AUTH_TOKEN (if Cloudflare AI Gateway testing is enabled)
#   - CLOUDFLARE_AI_GATEWAY_NAME       (default: p402-preview)
#   - CLOUDFLARE_AI_GATEWAY_URL        (if generated outside code)
#   - CLOUDFLARE_WORKERS_AI_ENABLED    (if Workers AI is enabled)
#
# PAID-PILOT CHECKLIST (on top of the beta list):
#   - OpenRouter production workspace/key review
#   - OpenRouter attribution headers set (Referer + Title + Categories)
#   - OpenRouter ZDR / data-policy mapping reviewed
#   - Cloudflare gateway limits reviewed (if Cloudflare path is enabled)
#   - Cloudflare cache disabled for sensitive workflows
#   - ERC8004_*                (when reputation gates are enabled)
#   - SAFETY_*                 (when safety gates are enabled)
#   - FLIP_* and AEE_*         (for flip-readiness proof)
#   - SENTRY_DSN               (production observability)
#   - GA4_*                    (only if measurement is in scope)
#   - AP2_REQUIRE_SIGNATURES   (when mandate enforcement is enabled)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# ── Google OAuth (NextAuth provider) ─────────────────────────────────────────
# https://console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash recommended for Vercel: rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe Dashboard → Webhooks → signing secret (set after registering endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Products → price IDs
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ── OpenRouter — primary production LLM provider routing ────────────────────
# OpenRouter is the production execution layer for P402 LLM calls.
# P402 wraps OpenRouter with budget, attribution, receipts, evidence, privacy,
# outcomes, and settlement. Clients must never call OpenRouter directly.
#
# Required (wired in code today):
#   OPENROUTER_API_KEY  — referenced by lib/ai-providers/openrouter.ts,
#       lib/cache/semantic-cache.ts, lib/retrieval/embed.ts,
#       app/api/v2/models/route.ts, and the model-sync cron.
#   OPENROUTER_REFERER  — sent as HTTP-Referer on every OpenRouter call
#       (lib/ai-providers/openrouter.ts:208). Required for app attribution
#       in OpenRouter rankings/analytics. Defaults to https://p402.io if unset;
#       set explicitly in production.
#
# Server-only; NEVER prefix with NEXT_PUBLIC.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_REFERER=

# ── OpenRouter — planned 3R-F hardening surface (not yet wired in code) ──────
# Declared here so operators can stage values in Vercel ahead of the planned
# 3R-F OpenRouter Provider Hardening slice. Setting these today is a no-op —
# the OpenRouter adapter does not read them yet. Do not depend on them for
# production invariants.
#
# X-OpenRouter-Title header — app attribution title shown in OpenRouter rankings.
OPENROUTER_APP_TITLE=P402
# Comma-separated OpenRouter app categories for ranking/analytics.
OPENROUTER_CATEGORIES=cli-agent,cloud-agent
# 'true' to opt the adapter into X-OpenRouter-Experimental-Metadata. Debug
# / Prove annotation only. Do not use router metadata for budget truth,
# settlement truth, receipt truth, or Optimize claims (OpenRouter marks the
# field set unstable).
OPENROUTER_ENABLE_ROUTER_METADATA=false
# 'true' to opt sanctioned deterministic, non-sensitive workflows into the
# OpenRouter response cache (beta). Never enable globally; per-workflow only.
# Do not enable for healthcare, legal, real-estate, or tenant-sensitive
# workflows by default.
OPENROUTER_ENABLE_RESPONSE_CACHE=false
# Default service_tier when a workflow does not specify one: 'flex' | 'priority'.
# Workflow / tenant policy must override; this is only the fallback default.
OPENROUTER_DEFAULT_SERVICE_TIER=
# 'true' only when tenant/workflow privacy policy requires Zero Data Retention
# as the default routing constraint. ZDR reduces eligible endpoints and can
# lower availability — treat as a policy decision, not a blanket default.
OPENROUTER_DEFAULT_ZDR=false

# ── AI Providers — direct-provider fallback / future direct-provider paths ──
# OpenRouter is the primary route above. These keys are optional unless the
# corresponding provider is used directly (without OpenRouter in front).
# Required for Gemini intelligence layer + text-embedding-004 (semantic cache).
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional — covered by OpenRouter when the OpenRouter route is used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Base Network ──────────────────────────────────────────────────────────────
# RPC endpoint for on-chain reads/writes (subscription billing, x402 settlement)
# Defaults to public https://mainnet.base.org if not set (rate-limited)
# Recommended: Alchemy/QuickNode Base endpoint for production
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
# Treasury address — must match the address set in deployed contracts
P402_TREASURY_ADDRESS=0xFa772434DCe6ED78831EbC9eeAcbDF42E2A031a6

# ── Coinbase Developer Platform (CDP) ────────────────────────────────────────
# https://portal.cdp.coinbase.com → API Keys
# Required for: CDP Embedded Wallet (email OTP auth) + CDP Server Wallet (TEE key storage)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# CDP project ID for embedded wallet (frontend)
NEXT_PUBLIC_CDP_PROJECT_ID=81080910-ed18-480f-8633-70289ef0baac
# Optional: custom name for the facilitator server wallet (default: p402-facilitator)
CDP_FACILITATOR_WALLET_NAME=p402-facilitator
# Set to true to use CDP Server Wallet instead of raw private key for settlement
CDP_SERVER_WALLET_ENABLED=false

# ── x402 Facilitator ──────────────────────────────────────────────────────────
# Legacy raw private key — only required when CDP_SERVER_WALLET_ENABLED=false
# When CDP_SERVER_WALLET_ENABLED=true, keys live in CDP TEE (AWS Nitro Enclave)
P402_SIGNER_ADDRESS=0x...
P402_FACILITATOR_PRIVATE_KEY=0x...
# Receipt HMAC signing key — required. Generate: openssl rand -hex 32
P402_RECEIPT_SECRET=

# ── Deployed Contracts (Base Mainnet) ─────────────────────────────────────────
# Fee-collecting marketplace settlement contract (1% fee → treasury)
P402_SETTLEMENT_ADDRESS=0xd03c7ab9a84d86dbc171367168317d6ebe408601
# EIP-2612 permit-based subscription billing ($499/mo USDC → treasury)
SUBSCRIPTION_FACILITATOR_ADDRESS=0xc64747651e977464af5bce98895ca6018a3e26d7
# Conditional USDC escrow (Phase 3 — deployed 2026-03-22)
P402_ESCROW_ADDRESS=0x4596c0e69d08e4ca6f02c7a129fc2bff8a6905ac

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://p402.io,https://www.p402.io,https://mini.p402.io

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=
# Auth token for Vercel cron jobs
CRON_SECRET=
# Auth token for internal poll endpoints
POLL_SECRET=

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_SEMANTIC_CACHE=true
ENABLE_COST_INTELLIGENCE=true

# ── Notifications (optional) ──────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin role on first login
ADMIN_EMAILS=

# ── Tempo Mainnet Direct facilitator (all optional; only required when Tempo adapter is enabled) ──
# Treasury address that receives settled TIP-20 stablecoins on Tempo mainnet (chain ID 4217).
# Must be stored in EIP-55 checksummed form (preserve the exact case).
TEMPO_TREASURY_ADDRESS=
# Private key for the Tempo treasury wallet.
# SENSITIVE — load from secrets manager in production; never commit this value.
TEMPO_TREASURY_PRIVATE_KEY=
# Tempo mainnet JSON-RPC endpoint. Default public endpoint: https://rpc.tempo.xyz
# (WSS: wss://rpc.tempo.xyz). Use a private node for production throughput.
# ⚠ viem 2.46.3 ships `tempo` chain with a stale URL (rpc.presto.tempo.xyz — pre-mainnet
#   codename). This env var overrides it. If unset, lib/constants/tempo.ts falls back to
#   https://rpc.tempo.xyz directly.
TEMPO_RPC_URL=https://rpc.tempo.xyz
# Supported TIP-20 stablecoin contracts are defined in lib/constants/tempo.ts
# (TEMPO_SUPPORTED_CURRENCIES) and synced to the DB via migration v2_038.
# No per-currency env vars needed — add new tokens to the constants file instead.

# ── mppx Dual-Protocol Payment Gate (Phase 2.1) ─────────────────────────────
# Enable the mppx/tempo payment path on /api/v2/chat/completions.
# When true: clients with "Authorization: Payment <...>" header pay per-request.
# Clients without payment credentials that also lack an API key receive a dual
# 402 response with both WWW-Authenticate (mppx) and X-PAYMENT-REQUIRED (x402).
# x402 X-PAYMENT backwards-compat guaranteed through May 2027.
USE_MPP_METHOD=false
# HMAC secret for mppx challenge signing. Generate: openssl rand -hex 32
# Required when USE_MPP_METHOD=true. Min 32 chars.
MPP_SECRET_KEY=
# Per-request charge amount in human-readable USDC decimal (mppx format).
# Default: 0.001 = $0.001 = 1000 raw USDC.e units. Dynamic per-token pricing: Phase 3.3.
MPP_CHARGE_AMOUNT_USD=0.001
# Switch to the @p402/mpp-method p402Charge method instead of native tempo().
# When true: uses P402's own credential format (sessionToken + ECDSA signature).
# P402_FACILITATOR_PRIVATE_KEY is NOT required in this mode.
# verifyP402Charge() stub returns success; real settlement wired in Phase 3.
USE_P402_MPP_METHOD=false

# ── Phase 1 Tempo Settlement Test (local dev only — NEVER add to Vercel) ─────
# These variables are used ONLY by scripts/test-tempo-settlement.ts.
# CRITICAL: TEST_SENDER_PRIVATE_KEY is sensitive material.
#   - NEVER add it to Vercel env vars.
#   - NEVER commit it (it must stay in .env.local only).
#   - Use it only on your developer laptop for end-to-end settlement testing.
#   - The test sender wallet exists for Phase 1 E2E testing only.
#     It is NOT a treasury and should hold only small balances (~$5 USDC.e).
#   - Derives to address 0x66BFD98Eddb19EdD8b357ccd67fBDdA41ddB3A2b on Tempo mainnet.
#     The script validates this derivation at startup and refuses to proceed if it mismatches.
TEST_SENDER_ADDRESS=0x66BFD98Eddb19EdD8b357ccd67fBDdA41ddB3A2b
TEST_SENDER_PRIVATE_KEY=

# Set to 'true' to actually submit a transaction in scripts/test-tempo-settlement.ts.
# Default (unset or any other value) runs the script in dry-run mode with no spending.
# After a successful live run, .tempo-settle-result.json is written to the repo root as
# an idempotency marker; delete it before running live again (prevents double-spending).
TEMPO_LIVE_SETTLE=

# ── ERC-8004 Trustless Agents (all optional, default disabled) ────────────────
ERC8004_AGENT_ID=
ERC8004_AGENT_URI=https://p402.io/.well-known/erc8004.json
ERC8004_TESTNET=false
ERC8004_ENABLE_REPUTATION=false
ERC8004_ENABLE_VALIDATION=false

# ── World Mini App ────────────────────────────────────────────────────────────
# App ID from developer.worldcoin.org (also set as NEXT_PUBLIC_APP_ID in p402_world Vercel project)
NEXT_PUBLIC_APP_ID=app_...
# Action ID registered in Developer Portal → Actions (used for World ID proof verification)
WORLD_ACTION_ID=p402-free-credits
# Action ID used client-side in the mini app (must match WORLD_ACTION_ID)
NEXT_PUBLIC_WORLD_ACTION_ID=p402-free-credits

# ── Dune Analytics (optional, for dune-sync.ts) ──────────────────────────────
# https://dune.com/settings/api
DUNE_API_KEY=
DUNE_NAMESPACE=p402   # your Dune username / namespace

# =============================================================================
# 3R-C additions — Production environment surface previously undocumented.
# Documentation only; no code defaults changed.
# =============================================================================

# ── Application runtime ──────────────────────────────────────────────────────
# Runtime tag: 'development' | 'staging' | 'production' | 'test'
ENVIRONMENT=
# Verbose logging toggle. Leave unset in production.
DEBUG=
# Canonical public URL for the deployment. Used in client links, OAuth callbacks,
# x402 metadata. Falls back to http://localhost:3000 when unset (lib/env.ts).
NEXT_PUBLIC_APP_URL=
# Optional public base URL when a separate marketing/app split is in use.
NEXT_PUBLIC_BASE_URL=
# Chain environment switch: 'mainnet' | 'testnet'. Drives client-side wallet config.
NEXT_PUBLIC_CHAIN_ENV=
# Demo banner toggle: '1' to enable. Public (client-visible) by design.
NEXT_PUBLIC_DEMO_MODE=

# ── Database / Cache (extensions) ────────────────────────────────────────────
# SSL enforcement flag for the Postgres driver. Recommended 'true' on Neon.
DATABASE_SSL=
# Alternative Redis URL (Upstash flavor). Code prefers REDIS_URL; this is a fallback.
UPSTASH_REDIS_URL=

# ── Cloudflare — secondary AI gateway and Workers AI (3R-F2, not yet wired) ─
# Cloudflare is the secondary, credit-backed AI execution path for P402.
# Roles:
#   - Cloudflare AI Gateway: edge observability, cache/DLP/log/rate-limit
#     experiments, secondary gateway in front of frontier-model providers.
#   - Cloudflare Workers AI: low-cost approved inference and embeddings for
#     internal classifiers, demo workloads, and non-sensitive deterministic
#     jobs.
# Cloudflare must NOT become the economic source of truth. Cloudflare cache
# hits must still become P402 economic events. Cloudflare logs do not replace
# P402 Prove. Cloudflare DLP is defense-in-depth, not the only privacy layer.
#
# None of these variables are wired in code today — declared here so operators
# can stage Vercel values ahead of the planned 3R-F2 Cloudflare Adapter Spike.
# Setting them today is a no-op until the adapter lands.
#
# Cloudflare account id. Required when using Workers AI or AI Gateway.
CLOUDFLARE_ACCOUNT_ID=
# Cloudflare API token for Workers AI / AI Gateway operations.
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
CLOUDFLARE_API_TOKEN=
# Cloudflare AI Gateway Authenticated Gateway token. Required when the gateway
# is configured with authenticated access (the p402-preview gateway is).
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
CLOUDFLARE_AI_GATEWAY_AUTH_TOKEN=
# Cloudflare AI Gateway name for routed AI traffic. Default is the preview
# gateway created for the 3R-F2 spike.
CLOUDFLARE_AI_GATEWAY_NAME=p402-preview
# Cloudflare AI Gateway base URL if generated or managed outside the code.
CLOUDFLARE_AI_GATEWAY_URL=
# Toggle Cloudflare AI Gateway adapter.
CLOUDFLARE_AI_GATEWAY_ENABLED=false
# Toggle Workers AI adapter for approved low-cost inference.
CLOUDFLARE_WORKERS_AI_ENABLED=false
# Default Workers AI chat model identifier.
CLOUDFLARE_WORKERS_AI_CHAT_MODEL=
# Default Workers AI embedding model identifier.
CLOUDFLARE_WORKERS_AI_EMBEDDING_MODEL=
# Enable Cloudflare AI Gateway cache ONLY for approved deterministic,
# non-sensitive workflows. Never enable for healthcare, legal, real-estate,
# or tenant-sensitive workflows by default.
CLOUDFLARE_AI_GATEWAY_CACHE_ENABLED=false
# Default Cloudflare AI Gateway cache TTL, in seconds.
CLOUDFLARE_AI_GATEWAY_CACHE_TTL_SECONDS=

# ── Additional AI Providers (all optional unless the provider is routed) ─────
# OpenRouter is the primary production LLM route (see section above). The keys
# below are needed only for direct-provider integrations or as fallback paths.
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
# Required only when Gemini intelligence, semantic-cache embeddings, or other
# Gemini-specific features are enabled in the deployed product.
GEMINI_API_KEY=
# Optional legacy/direct Google AI alias. Prefer GEMINI_API_KEY unless source
# code requires this name.
GOOGLE_AI_API_KEY=
# Optional direct-provider keys. Use only when direct-provider routing is
# enabled.
AI21_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=

# ── Multi-chain RPC + public signer addresses ────────────────────────────────
# Production-required for Base mainnet ops; the public default is rate-limited.
BASE_RPC_URL=
# Testnet RPC for preview / staging deployments.
BASE_SEPOLIA_RPC_URL=
# Arc-chain RPC + signer (optional; only when Arc adapter is enabled).
ARC_RPC_URL=
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
ARC_PRIVATE_KEY=
NEXT_PUBLIC_ARC_SIGNER_ADDRESS=
# Public Tempo signer address (matches the on-chain signer for verification).
NEXT_PUBLIC_TEMPO_SIGNER_ADDRESS=
# WalletConnect project id (public).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Additional x402 / payment ────────────────────────────────────────────────
# Prefer P402_FACILITATOR_PRIVATE_KEY for P402 app configuration. FACILITATOR_PRIVATE_KEY
# exists for legacy scripts or compatibility until source cleanup. secret, set in Vercel,
# never prefix with NEXT_PUBLIC.
FACILITATOR_PRIVATE_KEY=
# Generic wallet key used by scripts / fallback paths. secret, server-only.
WALLET_PRIVATE_KEY=
# Payer key used by integration scripts. secret, server-only.
PAYER_PRIVATE_KEY=
# Hardhat contract deploys (deploy-time only — not used by the running app).
# secret, never set on Vercel runtime; keep in deployer machine env.
DEPLOYER_PRIVATE_KEY=
# Example value for the P402 SDK Bearer token. secret, set in Vercel.
P402_API_KEY=
# Optional gas-price ceiling in Gwei (string).
P402_MAX_GAS_PRICE_GWEI=
# Router base URL used by SDK examples and client integration tests.
P402_ROUTER_URL=
# Client-side session id used in onboarding examples (not a secret).
P402_SESSION_ID=
# Client-visible wallet address used in examples.
P402_WALLET=
# Nanopayments external API base URL.
NANOPAYMENTS_API_BASE=
# Chainlink CCIP router (cross-chain). Optional unless CCIP is wired.
CCIP_ROUTER_ADDRESS=
# Circle USDC API key. secret, server-only.
CIRCLE_API_KEY=
# Agent-side treasury and discovery URL.
AGENT_TREASURY_ADDRESS=
AGENT_URL=

# ── AgentKit (World) ─────────────────────────────────────────────────────────
# Enable World AgentKit free-trial path.
AGENTKIT_ENABLED=
# Per-human free-trial use count.
AGENTKIT_FREE_TRIAL_USES=

# ── Budget guard / runtime gates ─────────────────────────────────────────────
# Load-bearing. Controls which spend source budget guard reads.
# Do not change in production without passing flip-readiness gates.
# Runtime flip remains blocked unless explicitly approved.
BUDGET_GUARD_SPEND_SOURCE=
# Flip-readiness toggles ('true' / 'false'). Defaults live in lib/flip-readiness/thresholds.ts;
# overrides here change which gates the readiness loader enforces.
FLIP_REQUIRE_BILLING_CYCLE=
FLIP_REQUIRE_DENIED_WRITE_PATH=
# AI economic events denied-write-path proof. 'enabled' wires the write path;
# the _TEST_PROVEN flags are CI-attested asserts surfaced into readiness.
AEE_DENIED_WRITE_PATH=
AEE_DENIED_WRITE_PATH_TEST_PROVEN=
AEE_DENIED_EVENT_KIND_TEST_PROVEN=
# Outcome coverage thresholds (numeric overrides). Code defaults live in
# lib/prove/coverage.ts; leave unset to use the canonical defaults.
OUTCOME_MIN_COVERAGE_PCT=
OUTCOME_MIN_ACCEPTED_COUNT=
OUTCOME_MIN_BASELINE_DAYS=
# AP2 mandate signature enforcement. Set 'true' for paid pilot and beyond.
AP2_REQUIRE_SIGNATURES=

# ── ERC-8004 reputation / validation extras ──────────────────────────────────
ERC8004_REPUTATION_CACHE_TTL_MS=
ERC8004_VALIDATION_REGISTRY=
ERC8004_VALIDATION_THRESHOLD_USD=

# ── Safety / Sentinel ────────────────────────────────────────────────────────
SAFETY_AI_SCAN=
SAFETY_MIN_REPUTATION=
SAFETY_REQUIRE_IDENTITY=

# ── Analytics / observability ────────────────────────────────────────────────
# Sentry DSN — semi-secret; production observability.
SENTRY_DSN=
# GA4 Measurement Protocol — measurement id is public, API secret is server-only.
GA4_MEASUREMENT_ID=
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
GA4_API_SECRET=

# ── Admin / Internal security ────────────────────────────────────────────────
# Comma-separated CIDR allowlist for admin routes (optional).
ADMIN_ALLOWED_IPS=
# 32-byte hex key for AES-256-GCM TOTP encryption. Generate: openssl rand -hex 32
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
ADMIN_ENCRYPTION_KEY=
# Internal endpoint bearer token (cron, jobs, admin internal APIs).
# secret, set in Vercel, never prefix with NEXT_PUBLIC.
INTERNAL_API_SECRET=

# ── Partner program ──────────────────────────────────────────────────────────
PARTNER_ADMIN_EMAIL=
# Days back to honor partner attribution links.
PARTNER_ATTRIBUTION_DAYS=
# Batch size for the polling job (defaults in code).
POLL_BATCH_SIZE=

# ── Legacy / dev-only — do not set in production unless code owner confirms ──
# The Supabase variables below were referenced in legacy code paths but the
# active project is Neon-only per CLAUDE.md. Pending source cleanup; leave
# commented out. Do not uncomment without owner sign-off.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
#
# NODE_TLS_REJECT_UNAUTHORIZED relaxes Node's TLS verification. dev-only,
# never set in production.
# NODE_TLS_REJECT_UNAUTHORIZED=0
