# ============================================
# P402 Router — Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# ── Google OAuth (NextAuth provider) ─────────────────────────────────────────
# https://console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash recommended for Vercel: rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe Dashboard → Webhooks → signing secret (set after registering endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Products → price IDs
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ── AI Providers ──────────────────────────────────────────────────────────────
# OpenRouter covers 300+ models with one key (recommended as primary)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Required for Gemini intelligence layer + text-embedding-004 (semantic cache)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional — OpenRouter covers these providers too
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Base Network ──────────────────────────────────────────────────────────────
# RPC endpoint for on-chain reads/writes (subscription billing, x402 settlement)
# Defaults to public https://mainnet.base.org if not set (rate-limited)
# Recommended: Alchemy/QuickNode Base endpoint for production
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
# Treasury address — must match the address set in deployed contracts
P402_TREASURY_ADDRESS=0xFa772434DCe6ED78831EbC9eeAcbDF42E2A031a6

# ── Coinbase Developer Platform (CDP) ────────────────────────────────────────
# https://portal.cdp.coinbase.com → API Keys
# Required for: CDP Embedded Wallet (email OTP auth) + CDP Server Wallet (TEE key storage)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# CDP project ID for embedded wallet (frontend)
NEXT_PUBLIC_CDP_PROJECT_ID=81080910-ed18-480f-8633-70289ef0baac
# Optional: custom name for the facilitator server wallet (default: p402-facilitator)
CDP_FACILITATOR_WALLET_NAME=p402-facilitator
# Set to true to use CDP Server Wallet instead of raw private key for settlement
CDP_SERVER_WALLET_ENABLED=false

# ── x402 Facilitator ──────────────────────────────────────────────────────────
# Legacy raw private key — only required when CDP_SERVER_WALLET_ENABLED=false
# When CDP_SERVER_WALLET_ENABLED=true, keys live in CDP TEE (AWS Nitro Enclave)
P402_SIGNER_ADDRESS=0x...
P402_FACILITATOR_PRIVATE_KEY=0x...
# Receipt HMAC signing key — required. Generate: openssl rand -hex 32
P402_RECEIPT_SECRET=

# ── Deployed Contracts (Base Mainnet) ─────────────────────────────────────────
# Fee-collecting marketplace settlement contract (1% fee → treasury)
P402_SETTLEMENT_ADDRESS=0xd03c7ab9a84d86dbc171367168317d6ebe408601
# EIP-2612 permit-based subscription billing ($499/mo USDC → treasury)
SUBSCRIPTION_FACILITATOR_ADDRESS=0xc64747651e977464af5bce98895ca6018a3e26d7
# Conditional USDC escrow (Phase 3 — deployed 2026-03-22)
P402_ESCROW_ADDRESS=0x4596c0e69d08e4ca6f02c7a129fc2bff8a6905ac

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://p402.io,https://www.p402.io,https://mini.p402.io

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=
# Auth token for Vercel cron jobs
CRON_SECRET=
# Auth token for internal poll endpoints
POLL_SECRET=

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_SEMANTIC_CACHE=true
ENABLE_COST_INTELLIGENCE=true

# ── Notifications (optional) ──────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin role on first login
ADMIN_EMAILS=

# ── ERC-8004 Trustless Agents (all optional, default disabled) ────────────────
ERC8004_AGENT_ID=
ERC8004_AGENT_URI=https://p402.io/.well-known/erc8004.json
ERC8004_TESTNET=false
ERC8004_ENABLE_REPUTATION=false
ERC8004_ENABLE_VALIDATION=false

# ── World Mini App ────────────────────────────────────────────────────────────
# App ID from developer.worldcoin.org (also set as NEXT_PUBLIC_APP_ID in p402_world Vercel project)
NEXT_PUBLIC_APP_ID=app_...
# Action ID registered in Developer Portal → Actions (used for World ID proof verification)
WORLD_ACTION_ID=p402-free-credits
# Action ID used client-side in the mini app (must match WORLD_ACTION_ID)
NEXT_PUBLIC_WORLD_ACTION_ID=p402-free-credits

# ── Dune Analytics (optional, for dune-sync.ts) ──────────────────────────────
# https://dune.com/settings/api
DUNE_API_KEY=
DUNE_NAMESPACE=p402   # your Dune username / namespace
