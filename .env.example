# ============================================
# P402 Router — Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# ── Google OAuth (NextAuth provider) ─────────────────────────────────────────
# https://console.cloud.google.com → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash recommended for Vercel: rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe Dashboard → Webhooks → signing secret (set after registering endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Products → price IDs
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ── AI Providers ──────────────────────────────────────────────────────────────
# OpenRouter covers 300+ models with one key (recommended as primary)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Required for Gemini intelligence layer + text-embedding-004 (semantic cache)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional — OpenRouter covers these providers too
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── x402 Facilitator ──────────────────────────────────────────────────────────
# Production wallet that signs EIP-3009 authorizations and pays Base gas
P402_SIGNER_ADDRESS=0x...
P402_FACILITATOR_PRIVATE_KEY=0x...

# ── Deployed Contracts (Base Mainnet) ─────────────────────────────────────────
# Fee-collecting marketplace settlement contract (1% fee → treasury)
P402_SETTLEMENT_ADDRESS=0xd03c7ab9a84d86dbc171367168317d6ebe408601
# EIP-2612 permit-based subscription billing ($499/mo USDC → treasury)
SUBSCRIPTION_FACILITATOR_ADDRESS=0xc64747651e977464af5bce98895ca6018a3e26d7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://p402.io,https://www.p402.io,https://mini.p402.io

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=
# Auth token for Vercel cron jobs
CRON_SECRET=
# Auth token for internal poll endpoints
POLL_SECRET=

# ── Features ──────────────────────────────────────────────────────────────────
ENABLE_SEMANTIC_CACHE=true
ENABLE_COST_INTELLIGENCE=true

# ── Notifications (optional) ──────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin role on first login
ADMIN_EMAILS=

# ── ERC-8004 Trustless Agents (all optional, default disabled) ────────────────
ERC8004_AGENT_ID=
ERC8004_AGENT_URI=https://p402.io/.well-known/erc8004.json
ERC8004_TESTNET=false
ERC8004_ENABLE_REPUTATION=false
ERC8004_ENABLE_VALIDATION=false
