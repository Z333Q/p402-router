{
  "name": "p402-router",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:a2a": "tsx scripts/test-a2a.ts",
    "test:build": "vitest run __tests__/build-smoke.test.ts",
    "test:routes": "vitest run __tests__/route-integrity.test.ts __tests__/api-exports.test.ts",
    "test:all": "vitest run && vitest run __tests__/build-smoke.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:resilience": "playwright test tests/e2e/error-resilience.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "build:skill": "chmod +x scripts/build-skill.sh && ./scripts/build-skill.sh",
    "prebuild": "npm run build:skill",
    "prepare": "husky install",
    "test:e2e:live": "playwright test --project=live-smoke --project=live-api --project=live-dashboard --project=live-admin",
    "test:e2e:live:setup": "playwright test --project=live-user-setup --project=live-admin-setup",
    "test:e2e:live:smoke": "playwright test --project=live-smoke",
    "test:e2e:live:api": "playwright test --project=live-api",
    "test:e2e:live:dashboard": "playwright test --project=live-dashboard",
    "test:e2e:live:admin": "playwright test --project=live-admin"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@coinbase/agentkit": "^0.10.4",
    "@coinbase/cdp-core": "^0.0.93",
    "@coinbase/cdp-hooks": "^0.0.93",
    "@coinbase/cdp-sdk": "^1.44.1",
    "@coinbase/cdp-wagmi": "^0.0.93",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "@p402/sdk": "file:sdk",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@tanstack/react-query": "^5.25.0",
    "@types/pg": "^8.16.0",
    "@worldcoin/agentkit": "^0.1.5",
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "@x402/fetch": "^2.5.0",
    "clsx": "^2.1.1",
    "crypto-browserify": "^3.12.1",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "ip-address-validator": "^1.0.10",
    "lucide-react": "^0.561.0",
    "motion": "^12.34.3",
    "next": "^15.5.9",
    "next-auth": "^4.24.11",
    "pg": "^8.16.3",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.5.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.6.0",
    "stream-browserify": "^3.0.0",
    "stripe": "^20.3.1",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.0.0",
    "viem": "^2.42.0",
    "vm-browserify": "^1.1.2",
    "wagmi": "^2.5.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.0.10",
    "hardhat": "^2.22.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.16"
  }
}
